# ProofPass Smart Contracts Configuration Template
# Copy this file to '.env' and populate with your credentials

# Polygon Amoy JSON-RPC Endpoint (e.g. Alchemy, Infura, or public)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Private Key of the Deployer Wallet (MUST hold Amoy MATIC for deployment gas fees)
# Format: hex string without 0x prefix
PRIVATE_KEY=your_private_key_here
