# ProofPass Go API Backend Configuration Template
# Copy this file to '.env' and populate with your credentials

# Port the Gin server runs on (Default: 8080)
PORT=8080

# Supabase PostgreSQL Database URI Connection String
# Format: postgresql://[user]:[password]@[host]:5432/[db_name]
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# Polygon Amoy JSON-RPC Endpoint (e.g. Alchemy, Infura, or public)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# Deployed ProofPass Smart Contract Hex Address
# Format: hex string starting with 0x
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Private Key of the Issuer Wallet (Authorized to write/issue credentials on-chain)
# Format: hex string without 0x prefix
ISSUER_PRIVATE_KEY=your_issuer_private_key_here
